<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.blogapi.mapper.AdminUserMapper">

    <resultMap id="AdminUserResultMap" type="com.example.blogapi.domain.AdminUser">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password_hash" property="passwordHash"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="findByUsername" resultMap="AdminUserResultMap">
        select id, username, password_hash, created_at, updated_at
        from admin_user
        where username = #{username}
    </select>

    <select id="existsByUsername" resultType="boolean">
        select count(1) > 0
        from admin_user
        where username = #{username}
    </select>

    <insert id="insert" parameterType="com.example.blogapi.domain.AdminUser" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        insert into admin_user (username, password_hash)
        values (#{username}, #{passwordHash})
    </insert>
</mapper>
